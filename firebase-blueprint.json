{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user information and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user." },
        "displayName": { "type": "string", "description": "User's display name." },
        "email": { "type": "string", "format": "email", "description": "User's email address." },
        "photoURL": { "type": "string", "description": "URL to the user's profile picture." },
        "role": { "type": "string", "enum": ["admin", "user", "developer", "guest"], "description": "User's role for RBAC." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." }
      },
      "required": ["uid", "email"]
    },
    "Conversation": {
      "title": "Conversation Session",
      "description": "Stores chat history between a user and an agent.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "agentId": { "type": "string" },
        "title": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "agentId"]
    },
    "Message": {
      "title": "Chat Message",
      "description": "A single message in a conversation.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "conversationId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model"] },
        "parts": { "type": "array", "items": { "type": "object" } },
        "timestamp": { "type": "number" }
      },
      "required": ["conversationId", "role", "parts", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/conversations/{conversationId}": {
      "schema": "Conversation",
      "description": "Chat sessions."
    },
    "/conversations/{conversationId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a session."
    }
  }
}
